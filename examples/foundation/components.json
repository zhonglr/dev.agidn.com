        "emphasis": { "displayName": { "en-US": "Emphasis", "zh-CN": "强调" } }
      },
      "tokenSlots": {
        "textColor": { "displayName": { "en-US": "Text color", "zh-CN": "文字颜色" }, "tokenTypes": ["color"] },
        "typography": { "displayName": { "en-US": "Typography", "zh-CN": "排版" }, "tokenTypes": ["typography"] }
