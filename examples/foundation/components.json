          "editor": "text"
        },
        "level": {
          "type": "enum",
          "displayName": { "en-US": "Level", "zh-CN": "层级" },
          "required": true,
          "defaultValue": 2,
          "values": [1, 2, 3, 4, 5, 6],
          "editor": "select"
        }
      },
      "slots": {},
      "variants": {
        "display": { "displayName": { "en-US": "Display", "zh-CN": "展示" } },
        "title": { "displayName": { "en-US": "Title", "zh-CN": "标题" } },
        "section": { "displayName": { "en-US": "Section", "zh-CN": "章节" } }
      },
      "tokenSlots": {
        "textColor": { "displayName": { "en-US": "Text color", "zh-CN": "文字颜色" }, "tokenTypes": ["color"] },
        "typography": { "displayName": { "en-US": "Typography", "zh-CN": "排版" }, "tokenTypes": ["typography"] }
      },
      "events": {},
      "accessibility": { "accessibleName": "none" },
      "editor": {
        "icon": "heading",
        "keywords": ["heading", "title", "标题"],
        "presets": {
          "title": {
            "displayName": { "en-US": "Heading", "zh-CN": "标题" },
            "variant": "title",
            "props": { "text": "Heading", "level": 2 }
          }
        },
        "defaultPreset": "title"
      }
    },
    "Text": {
      "name": "Text",
      "version": "2.0.0",
