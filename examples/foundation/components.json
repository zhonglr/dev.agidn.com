{
  "schemaVersion": "2.0.0",
  "components": {
    "Button": {
      "name": "Button",
      "version": "2.0.0",
      "source": "@agidn/foundation/Button",
      "displayName": { "en-US": "Button", "zh-CN": "按钮" },
      "description": { "en-US": "Triggers an action.", "zh-CN": "触发一个操作。" },
      "category": "action",
      "roles": ["primary-action", "secondary-action"],
      "props": {
        "label": {
          "type": "string",
          "displayName": { "en-US": "Label", "zh-CN": "文本" },
          "required": true,
          "defaultValue": "Button",
          "editor": "text"
        },
        "disabled": {
          "type": "boolean",
          "displayName": { "en-US": "Disabled", "zh-CN": "禁用" },
          "required": false,
          "defaultValue": false,
          "editor": "switch"
        },
        "iconOnly": {
          "type": "boolean",
          "displayName": { "en-US": "Icon only", "zh-CN": "仅图标" },
          "required": false,
          "defaultValue": false,
          "editor": "switch"
        }
      },
      "slots": {
        "leadingIcon": {
          "displayName": { "en-US": "Leading icon", "zh-CN": "前置图标" },
          "valueType": "nodes",
          "accepts": ["Icon"],
          "required": false,
          "minItems": 0,
          "maxItems": 1
        },
        "trailingIcon": {
          "displayName": { "en-US": "Trailing icon", "zh-CN": "后置图标" },
          "valueType": "nodes",
          "accepts": ["Icon"],
          "required": false,
          "minItems": 0,
          "maxItems": 1
        }
      },
      "variants": {
        "primary": { "displayName": { "en-US": "Primary", "zh-CN": "主要" } },
        "secondary": { "displayName": { "en-US": "Secondary", "zh-CN": "次要" } },
        "danger": { "displayName": { "en-US": "Danger", "zh-CN": "危险" } },
        "ghost": { "displayName": { "en-US": "Ghost", "zh-CN": "幽灵" } }
      },
      "tokenSlots": {
        "textColor": { "displayName": { "en-US": "Text color", "zh-CN": "文字颜色" }, "tokenTypes": ["color"] },
        "surfaceColor": { "displayName": { "en-US": "Surface color", "zh-CN": "表面颜色" }, "tokenTypes": ["color"] },
        "radius": { "displayName": { "en-US": "Radius", "zh-CN": "圆角" }, "tokenTypes": ["radius"] }
      },
      "events": { "press": { "displayName": { "en-US": "Press", "zh-CN": "点击" } } },
      "accessibility": { "accessibleName": "when-icon-only", "iconOnlyProp": "iconOnly" },
      "editor": {
        "icon": "button",
        "keywords": ["button", "action", "按钮"],
        "presets": {
          "primary": {
            "displayName": { "en-US": "Primary button", "zh-CN": "主要按钮" },
            "variant": "primary",
            "props": { "label": "Button" }
          }
        },
        "defaultPreset": "primary"
      }
    },
    "Link": {
      "name": "Link",
      "version": "2.0.0",
      "source": "@agidn/foundation/Link",
      "displayName": { "en-US": "Link", "zh-CN": "链接" },
      "description": { "en-US": "Navigates to a destination.", "zh-CN": "跳转到目标地址。" },
      "category": "action",
      "roles": ["navigation-link"],
      "props": {
        "label": {
          "type": "string",
          "displayName": { "en-US": "Label", "zh-CN": "文本" },
          "required": true,
          "defaultValue": "Link",
          "editor": "text"
        },
        "href": {
          "type": "string",
          "displayName": { "en-US": "URL", "zh-CN": "链接地址" },
          "required": true,
          "defaultValue": "#",
          "editor": "url"
        },
        "external": {
          "type": "boolean",
          "displayName": { "en-US": "External", "zh-CN": "外部链接" },
          "required": false,
          "defaultValue": false,
          "editor": "switch"
        }
      },
      "slots": {},
      "variants": {
        "default": { "displayName": { "en-US": "Default", "zh-CN": "默认" } },
        "muted": { "displayName": { "en-US": "Muted", "zh-CN": "弱化" } }
      },
      "tokenSlots": {
        "textColor": { "displayName": { "en-US": "Text color", "zh-CN": "文字颜色" }, "tokenTypes": ["color"] }
      },
      "events": { "press": { "displayName": { "en-US": "Press", "zh-CN": "点击" } } },
      "accessibility": { "accessibleName": "none" },
      "editor": {
        "icon": "link",
        "keywords": ["link", "navigation", "链接"],
        "presets": {
          "default": {
            "displayName": { "en-US": "Link", "zh-CN": "链接" },
            "variant": "default",
            "props": { "label": "Link", "href": "#" }
          }
        },
        "defaultPreset": "default"
      }
    },
    "Heading": {
      "name": "Heading",
      "version": "2.0.0",
      "source": "@agidn/foundation/Heading",
      "displayName": { "en-US": "Heading", "zh-CN": "标题" },
