{
  "schemaVersion": "1.0.0",
  "id": "page_pricing",
  "kind": "page",
  "role": "pricing-page",
  "name": "Acme Pricing",
  "children": [
    {
      "id": "section_header",
      "kind": "layout",
      "role": "site-header",
      "layout": "section",
      "children": [
        {
          "id": "container_header",
          "kind": "layout",
          "layout": "container",
          "width": "lg",
          "children": [
            {
              "id": "navigation_main",
              "kind": "component",
              "role": "primary-navigation",
              "componentRef": "Navigation",
              "variant": "header",
              "props": { "label": "Primary navigation" },
              "slots": {
                "items": [
                  { "id": "link_features", "kind": "component", "componentRef": "Link", "variant": "default", "props": { "label": "Features", "href": "/features" } },
                  { "id": "link_pricing", "kind": "component", "componentRef": "Link", "variant": "default", "props": { "label": "Pricing", "href": "/pricing" } }
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "id": "section_hero",
      "kind": "layout",
      "role": "hero",
      "layout": "section",
      "children": [
        {
          "id": "container_hero",
          "kind": "layout",
          "layout": "container",
          "width": "md",
          "children": [
            {
              "id": "stack_hero",
              "kind": "layout",
              "layout": "stack",
              "align": "center",
              "gapToken": "spacing.lg",
              "children": [
                { "id": "heading_hero", "kind": "component", "role": "primary-title", "componentRef": "Heading", "variant": "display", "props": { "text": "Simple pricing that scales with you", "level": 1 }, "tokens": { "textColor": "color.text.default", "typography": "typography.display" } },
                { "id": "text_hero", "kind": "component", "role": "description", "componentRef": "Text", "variant": "muted", "props": { "text": "Start free, then choose a plan when your team is ready." }, "tokens": { "textColor": "color.text.muted", "typography": "typography.body" } },
                { "id": "image_hero", "kind": "component", "role": "hero-media", "componentRef": "Image", "variant": "rounded", "props": { "src": "/assets/pricing-dashboard.webp", "alt": "Analytics dashboard preview" } },
                { "id": "icon_secure", "kind": "component", "role": "status-icon", "componentRef": "Icon", "variant": "success", "props": { "name": "shield-check", "decorative": true } }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "section_pricing",
      "kind": "layout",
      "role": "pricing-plans",
      "layout": "section",
      "children": [
        {
          "id": "container_pricing",
          "kind": "layout",
          "layout": "container",
          "width": "lg",
          "children": [
            {
              "id": "grid_plans",
              "kind": "layout",
              "layout": "grid",
              "columns": { "mobile": 1, "tablet": 2, "desktop": 3 },
              "gapToken": "spacing.lg",
              "children": [
                {
                  "id": "pricing_card_starter",
                  "kind": "component",
                  "role": "pricing-plan",
                  "componentRef": "PricingCard",
                  "variant": "default",
                  "props": { "planName": "Starter", "price": "$0", "featured": false },
                  "tokens": { "surfaceColor": "color.surface.default", "radius": "radius.card" },
                  "slots": {
                    "description": [{ "id": "text_starter_description", "kind": "component", "componentRef": "Text", "variant": "muted", "props": { "text": "For trying out the essentials." } }],
                    "features": [{ "id": "text_starter_feature", "kind": "component", "componentRef": "Text", "variant": "body", "props": { "text": "One project and community support" } }],
                    "action": [{ "id": "button_starter", "kind": "component", "role": "primary-action", "componentRef": "Button", "variant": "secondary", "props": { "label": "Start free", "iconOnly": false }, "interactions": [{ "event": "press", "actionRef": "billing.selectPlan", "arguments": { "planId": "starter" } }] }]
                  }
                },
                {
                  "id": "pricing_card_pro",
                  "kind": "component",
                  "role": "pricing-plan",
                  "componentRef": "PricingCard",
                  "variant": "featured",
                  "props": { "planName": "Pro", "price": "$29", "featured": true },
                  "tokens": { "surfaceColor": "color.surface.featured", "radius": "radius.card", "shadow": "shadow.card" },
                  "slots": {
                    "description": [{ "id": "text_pro_description", "kind": "component", "componentRef": "Text", "variant": "muted", "props": { "text": "For growing product teams." } }],
                    "features": [{ "id": "text_pro_feature", "kind": "component", "componentRef": "Text", "variant": "body", "props": { "text": "Unlimited projects and priority support" } }],
                    "action": [{ "id": "button_pro", "kind": "component", "role": "primary-action", "componentRef": "Button", "variant": "primary", "props": { "label": "Choose Pro", "iconOnly": false }, "interactions": [{ "event": "press", "actionRef": "billing.selectPlan", "arguments": { "planId": "pro" } }] }],
                    "badge": [{ "id": "badge_popular", "kind": "component", "role": "plan-highlight", "componentRef": "Badge", "variant": "accent", "props": { "label": "Most popular" }, "tokens": { "color": "color.action.primary" } }]
                  }
                },
                {
                  "id": "pricing_card_business",
                  "kind": "component",
                  "role": "pricing-plan",
                  "componentRef": "PricingCard",
                  "variant": "default",
                  "props": { "planName": "Business", "price": "$99", "featured": false },
                  "tokens": { "surfaceColor": "color.surface.default", "radius": "radius.card" },
                  "slots": {
                    "description": [{ "id": "text_business_description", "kind": "component", "componentRef": "Text", "variant": "muted", "props": { "text": "For organizations needing control." } }],
                    "features": [{ "id": "text_business_feature", "kind": "component", "componentRef": "Text", "variant": "body", "props": { "text": "Advanced permissions and SSO" } }],
                    "action": [{ "id": "button_business", "kind": "component", "role": "primary-action", "componentRef": "Button", "variant": "secondary", "props": { "label": "Choose Business", "iconOnly": false }, "interactions": [{ "event": "press", "actionRef": "billing.selectPlan", "arguments": { "planId": "business" } }] }]
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "section_faq",
      "kind": "layout",
      "role": "faq",
      "layout": "section",
      "children": [
        {
          "id": "container_faq",
          "kind": "layout",
          "layout": "container",
          "width": "md",
          "children": [
            {
              "id": "stack_faq",
              "kind": "layout",
              "layout": "stack",
              "gapToken": "spacing.md",
              "children": [
                { "id": "heading_faq", "kind": "component", "role": "section-title", "componentRef": "Heading", "variant": "section", "props": { "text": "Frequently asked questions", "level": 2 } },
                { "id": "faq_cancel", "kind": "component", "role": "faq-item", "componentRef": "FAQItem", "variant": "default", "state": "closed", "props": { "question": "Can I cancel at any time?", "answer": "Yes. Your plan remains active through the current billing period." } },
                { "id": "card_guarantee", "kind": "component", "role": "content-card", "componentRef": "Card", "variant": "outlined", "slots": { "content": [{ "id": "text_guarantee", "kind": "component", "componentRef": "Text", "variant": "emphasis", "props": { "text": "Every paid plan includes a 30-day money-back guarantee." } }] } }
              ]
            }
          ]
        }
      ]
    }
  ]
}
