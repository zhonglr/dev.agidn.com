{
  "name": "agidn-ui-builder",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "pnpm lint:code && pnpm lint:styles",
    "lint:code": "eslint . --max-warnings 0",
    "lint:styles": "stylelint \"apps/**/*.css\" \"packages/**/*.css\"",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm docs:check && vitest run",
    "test:e2e:studio": "node scripts/studio-browser-smoke.mjs",
    "test:watch": "vitest",
    "docs:check": "node scripts/check-docs.mjs",
    "reset:verify": "node scripts/verify-v2-reset.mjs",
    "dev": "pnpm --parallel --filter @agidn/studio --filter @agidn/workspace-server run dev",
    "studio": "pnpm --filter @agidn/studio dev",
    "studio:build": "pnpm --filter @agidn/studio build",
    "ui": "tsx apps/workspace-server/src/cli.ts",
    "workspace-server": "tsx apps/workspace-server/src/server.ts"
  },
  "devDependencies": {
    "@agidn/api-protocol": "workspace:*",
    "@agidn/command-engine": "workspace:*",
    "@agidn/component-registry": "workspace:*",
    "@agidn/context-exporter": "workspace:*",
    "@agidn/design-tokens": "workspace:*",
    "@agidn/document-codec": "workspace:*",
    "@agidn/document-engine": "workspace:*",
    "@agidn/document-schema": "workspace:*",
    "@agidn/layout-engine": "workspace:*",
    "@agidn/project-assets": "workspace:*",
    "@agidn/react-renderer": "workspace:*",
    "@agidn/rule-engine": "workspace:*",
    "@agidn/studio-workbench": "workspace:*",
    "@eslint/js": "^9.39.5",
    "@types/node": "^24.0.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "eslint": "^9.39.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.38"
  }
}
